+function buildPiAuthJsonFromProfiles(profiles) {
+  const auth = {};
+  for (const credential of Object.values(profiles || {})) {
+    if (!credential || typeof credential !== "object" || !credential.provider) {
+      continue;
+    }
+    const provider = String(credential.provider).trim();
+    if (!provider || auth[provider]) {
+      continue;
+    }
+    if (credential.type === "api_key" && typeof credential.key === "string" && credential.key) {
+      auth[provider] = { type: "api_key", key: credential.key };
+      continue;
+    }
+    if (credential.type === "token" && typeof credential.token === "string" && credential.token) {
+      auth[provider] = { type: "api_key", key: credential.token };
+      continue;
+    }
+    if (
+      credential.type === "oauth" &&
+      typeof credential.access === "string" &&
+      typeof credential.refresh === "string" &&
+      typeof credential.expires === "number"
+    ) {
+      auth[provider] = {
+        type: "oauth",
+        access: credential.access,
+        refresh: credential.refresh,
+        expires: credential.expires,
+        ...(typeof credential.accountId === "string" && credential.accountId
+          ? { accountId: credential.accountId }
+          : {}),
+        ...(typeof credential.email === "string" && credential.email
+          ? { email: credential.email }
+          : {}),
+        ...(typeof credential.projectId === "string" && credential.projectId
+          ? { projectId: credential.projectId }
+          : {}),
+        ...(typeof credential.enterpriseUrl === "string" && credential.enterpriseUrl
+          ? { enterpriseUrl: credential.enterpriseUrl }
+          : {}),
+      };
+    }
+  }
+  return auth;
+}
